<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.Animedia" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.Animedia.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/surface_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.Animedia.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Rounded image style -->
    <style name="Widget.Animedia.ImageView.Rounded" parent="android:Widget">
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.Animedia.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Animedia.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_md</item>
    </style>

    <style name="TextAppearance.Animedia.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>

    <style name="TextAppearance.Animedia.Badge" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:background">@drawable/bg_badge</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:paddingTop">@dimen/spacing_xs</item>
        <item name="android:paddingBottom">@dimen/spacing_xs</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.Animedia.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/radius_full</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Animedia.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_full</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Chip style -->
    <style name="Widget.Animedia.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_elevated</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="chipCornerRadius">@dimen/radius_full</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipMinHeight">32dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.Animedia.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_dark</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Animedia.BottomNav.Indicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.Animedia.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_light</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Animedia.SmallComponent</item>
    </style>

    <style name="ShapeAppearance.Animedia.SmallComponent" parent="">
        <item name="cornerSize">@dimen/radius_full</item>
    </style>

    <!-- Search bar -->
    <style name="Widget.Animedia.SearchBar" parent="Widget.Material3.SearchBar">
        <item name="android:background">@drawable/bg_search_bar</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="iconTint">@color/text_hint</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/radius_full</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>
