<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/card_poster_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Poster -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_poster_height">

            <ImageView
                android:id="@+id/imgPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/surface_elevated"
                android:contentDescription="Постер" />

            <TextView
                android:id="@+id/txtBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/spacing_sm"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="2dp"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:padding="@dimen/spacing_sm"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_xs" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
