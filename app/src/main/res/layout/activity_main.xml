<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            app:layout_scrollFlags="scroll|enterAlways"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Animedia"
                    android:textColor="@color/primary_light"
                    android:textSize="@dimen/text_xxl"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.02" />

                <ImageView
                    android:id="@+id/btnThemeToggle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_theme"
                    android:contentDescription="Тема"
                    android:layout_marginEnd="@dimen/spacing_md"/>

                <ImageView
                    android:id="@+id/btnProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_user"
                    android:contentDescription="Профиль" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_md"
            app:layout_scrollFlags="scroll|enterAlways">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchBar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_full"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_lg"
                    android:paddingEnd="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="Поиск"
                        app:tint="@color/text_hint" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="@string/search_hint"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Telegram Banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\uD83D\uDCE8"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="Мы в Telegram"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Подписаться \u2192"
                        android:textColor="@color/primary_light"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- New Episodes Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/new_episodes"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-bold" />

                <!-- View mode toggle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_chip"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn2D"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="2D"
                        android:textColor="@color/primary_light"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@color/divider" />

                    <TextView
                        android:id="@+id/btn3D"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="3D"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_xs" />
                </LinearLayout>
            </LinearLayout>

            <!-- New Episodes Carousel -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNewEpisodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingBottom="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Today Releases Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:text="@string/today_releases"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:fontFamily="sans-serif-bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTodayReleases"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingBottom="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Top Clans Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/top_clans"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_lg"
                    android:fontFamily="sans-serif-bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Все \u2192"
                    android:textColor="@color/primary_light"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/clansContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_sm" />

            <!-- Collections Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:text="@string/collections"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:fontFamily="sans-serif-bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCollections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingBottom="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- New Anime Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/new_anime"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Все \u2192"
                    android:textColor="@color/primary_light"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNewAnime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_sm"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:background="@color/surface_dark"
        app:elevation="8dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemActiveIndicatorStyle="@style/Widget.Animedia.BottomNav.Indicator"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
